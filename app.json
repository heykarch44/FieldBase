{
  "expo": {
    "name": "FieldIQ",
    "slug": "fieldiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "fieldiq",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d9488"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fieldiq.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Take photos of equipment and service work",
        "NSLocationWhenInUseUsageDescription": "Record GPS location for arrive/depart timestamps and verify clock-in location",
        "NSPhotoLibraryUsageDescription": "Select photos to attach to service visits",
        "NSFaceIDUsageDescription": "Use Face ID for quick login",
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Automatically clock you in and out when you arrive at or leave job sites",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ]
      },
      "buildNumber": "4"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0d9488"
      },
      "package": "com.fieldiq.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Take photos of equipment and service work"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Automatically clock you in and out when you arrive at or leave job sites",
          "locationWhenInUsePermission": "Record GPS location for arrive/depart timestamps and verify clock-in location",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID for quick login"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0d9488"
        }
      ],
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "Select photos to attach to service visits"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ff3d2b8a-478a-4be0-9e3e-f2bb7c71861d"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "heykarch44",
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 5000,
      "url": "https://u.expo.dev/ff3d2b8a-478a-4be0-9e3e-f2bb7c71861d"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}